              "name": "13. DELETE Post 1 — Stretch goal",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test('✅ Status 200 — JSONPlaceholder confirmó el delete', function () {",
                      "    pm.response.to.have.status(200);",
                      "});",
                      "",
                      "pm.test('📋 Sobre el DELETE', function () {",
                      "    const body = pm.response.json();",
